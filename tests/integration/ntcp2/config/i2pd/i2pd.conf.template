# Plan 038 i2pd 2.60.0 template; generated values remain in the run root.
daemon = false
loglevel = debug
netid = 99
address4 = @ADDRESS4@
address6 = @ADDRESS6@
host = @ADDRESS4@
port = @LOCAL_PORT@
ipv4 = @IPV4_ENABLED@
ipv6 = @IPV6_ENABLED@
notransit = true
floodfill = false
reservedrange = false

[ntcp2]
enabled = true
published = true
port = @LOCAL_PORT@

[ssu2]
enabled = false
published = false

[http]
enabled = true
port = 7070

[httpproxy]
enabled = false

[socksproxy]
enabled = false

[sam]
enabled = true
port = 7656

[i2cp]
enabled = false

[i2pcontrol]
enabled = false

[upnp]
enabled = false

[reseed]
verify = true
urls =
threshold = 0
